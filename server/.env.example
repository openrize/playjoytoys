# Copy this file to .env and fill in your real Stripe keys
# Get your keys at: https://dashboard.stripe.com/apikeys

# Use sk_test_... keys for testing, sk_live_... when going live
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_KEY

# Get this from: https://dashboard.stripe.com/webhooks (after creating a webhook)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# The URL of your frontend (used for redirect after payment)
FRONTEND_URL=http://localhost:4000

# Port for the server
PORT=4000
